    "lint": "eslint ./src",
    "build": "tsc",
    "lingui:extract": "lingui extract",
    "lingui:compile": "lingui compile",
    "prepare": "husky",
    "dev": "concurrently -n \"TypeScript,Pear\" -c \"blue,green\" \"tsc --watch\" \"pear run -d .\"",
    "build:dev:arm64": "APP_FILE=app.dev.cjs ./scripts/build-dmg-arm64.sh"
  },
