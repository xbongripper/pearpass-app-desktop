      "/node_modules/pearpass-lib-vault-core/src/worklet/app.js",
      "/subProcess/clipboardCleanup.js",
      "/workers/updater/index.js"
    ],
    "gui": {
      "backgroundColor": "#1F2430",
      "height": "1024",
      "width": "1440"
    },
    "links": [
      "https://hooks.slack.com/services/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",
      "https://docs.google.com/forms/d/e/1FAIpQLScLltvRe64VzMDRzOVjGtHWZ3KafLC2zzvkEoJfTzJkFd67OA/*"
    ],
    "stage": {
      "entrypoints": [
        "node_modules/pearpass-lib-vault-core/src/worklet/app.js",
        "subProcess/clipboardCleanup.js",
        "package.json",
        "/index.js"
      ],
      "prefetch": [
        "assets"
      ],
      "ignore": [
        ".github",
        "appling",
        ".git",
        ".gitignore",
        ".husky",
        "e2e",
        "scripts",
        "src",
        "tsconfig.json",
        "eslint.config.js",
        "jest.config.js",
        "flatpak",
        "snapcraft"
      ]
    }
  },
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "test": "jest",
    "build:pear": "lingui extract && lingui compile && tsc",
